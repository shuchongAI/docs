                "pages": ["en/api-reference/introduction"]
              }
            ]
          }
        ]
      },
      {
        "language": "cn",
        "tabs": [
          {
            "tab": "指南",
            "groups": [
              {
                "group": "开始使用",
                "pages": ["zh/index", "zh/quickstart", "zh/development"]
              },
              {
                "group": "自定义",
                "pages": ["zh/essentials/settings", "zh/essentials/navigation"]
              }
            ]
          },
          {
            "tab": "API 参考",
            "groups": [
              {
                "group": "API 文档",
                "pages": ["zh/api-reference/introduction"]
